# Ollama Configuration (Local LLM Server)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Ports for Flask applications
VULNERABLE_PORT=5000
HARDENED_PORT=5001

# Gemini API Keys (Google AI Studio)
# Get free keys at: https://aistudio.google.com → API keys
# Each key provides 1500 requests/day quota
# Add two keys from different Google accounts for quota rotation
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY=
